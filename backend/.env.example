# Copy this file to backend/.env and fill in real secrets.

LLM_API_KEY=your_deepseek_or_openai_compatible_api_key
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-chat
LLM_TIMEOUT_SECONDS=20
LLM_ENABLED=true
LLM_TOPIC_WINDOW_SECONDS=120
LLM_TOPIC_MAX_BLOCKS=80

ENHANCEMENT_MAX_SECONDS=300
ENHANCEMENT_CHUNK_SECONDS=60
ENHANCEMENT_MAX_CHUNKS=120
ENHANCEMENT_WORKERS=2
ENHANCEMENT_SKIP_SECONDS=0
ENHANCEMENT_PREGAIN_ENABLED=true
ENHANCEMENT_MAX_GAIN_DB=24
ENHANCEMENT_TARGET_LUFS=-18
ENHANCEMENT_CANDIDATES=deepfilternet,clearvoice
DEEPFILTERNET_BACKEND=cli
CLEARVOICE_ENHANCE_MODEL=MossFormer2_SE_48K
CLEARVOICE_USE_CUDA=auto
CLEARVOICE_ENHANCE_USE_CUDA=auto

CHUNK_SECONDS=60
CHUNK_OVERLAP_SECONDS=5
UPLOAD_CHUNK_MB=4

QUALITY_ROUTER_ENABLED=true
SEPARATION_BACKEND=speechbrain
SEPARATION_CANDIDATES=libri2mix,mossformer2,gated
# raw keeps blind source separation close to the model training distribution.
# ASR and summaries still use the enhanced audio from the main pipeline.
SEPARATION_INPUT_SOURCE=raw
SEPARATION_MIXTURE_CONSISTENCY=false
SEPARATION_STFT_MASK_REFINEMENT=true
SEPARATION_STFT_MASK_N_FFT=1024
SEPARATION_STFT_MASK_HOP=128
SEPARATION_STFT_MASK_POWER=1.5
SEPARATION_LOW_OVERLAP_LEAKAGE_SUPPRESSION=true
SEPARATION_LOW_OVERLAP_THRESHOLD=0.2
SEPARATION_LOW_OVERLAP_DOMINANCE_DB=3.0
SEPARATION_LOW_OVERLAP_LOSER_GAIN=0.1
SEPARATION_LOW_OVERLAP_ACTIVE_FLOOR_DB=-45
SEPARATION_SPEECHBRAIN_RESIDUAL_PROJECTION=true
SEPARATION_SPEECHBRAIN_RESIDUAL_PROJECTION_AMOUNT=1.0
SEPARATION_LIBRI2MIX_BONUS=1.5
SEPARATION_DIAGNOSTIC_RERANK=true
SEPARATION_MODEL=speechbrain/sepformer-libri2mix
SEPARATION_DEVICE=auto
MOSSFORMER2_SEPARATION_MODEL=MossFormer2_SS_16K
MOSSFORMER2_USE_CUDA=auto
MOSSFORMER2_DIAGNOSTIC_MIXCORR_THRESHOLD=0.986
MOSSFORMER2_DIAGNOSTIC_TRACK_OVERLAP_THRESHOLD=0.34
MOSSFORMER2_DIAGNOSTIC_SPEECHBRAIN_CORR_MAX=-0.0015
MOSSFORMER2_DIAGNOSTIC_BONUS=8.0
SPEAKER_TRACK_BACKGROUND_GAIN=0.015
SPEAKER_TRACK_TARGET_GAIN=1.25
SPEAKER_TRACK_FADE_MS=25
SPEAKER_TRACK_LIMIT=0.98
SEPARATION_MAX_SECONDS=60
SEPARATION_CHUNK_SECONDS=60
SEPARATION_MAX_CHUNKS=120
ASR_BACKEND=faster-whisper
ASR_MODEL=small
ASR_DEVICE=auto
ASR_COMPUTE_TYPE=auto
ASR_LANGUAGE=zh
ASR_MAX_SECONDS=600
ASR_CHUNK_SECONDS=60
ASR_MAX_CHUNKS=240
ASR_VAD_FILTER=true
ASR_BEAM_SIZE=1
ASR_BEST_OF=1
ASR_CPU_THREADS=0
ASR_NUM_WORKERS=1
ASR_CONDITION_ON_PREVIOUS_TEXT=false
